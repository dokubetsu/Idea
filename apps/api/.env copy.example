SUPABASE_URL=https://your-project.supabase.co
# Legacy keys (JWT based)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# New key methods (Publishable/Secret keys starting with sb_publishable_ / sb_secret_)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SECRET_KEY=sb_secret_your-key-here

SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# AI — leave blank to use mock
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
