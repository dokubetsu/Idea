# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# Use ONE of the two key styles below (new-style preferred):

# New-style keys (Publishable / Secret — starts with sb_publishable_ / sb_secret_)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SECRET_KEY=sb_secret_your-key-here

# Legacy JWT-based keys (use if your project doesn't have new-style keys yet)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# SUPABASE_ANON_KEY=your-supabase-anon-key-here

SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set at least ONE key. Falls back to mock if all are empty.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: override provider explicitly (gemini | claude | openai_compatible | mock)
# AI_PROVIDER_TYPE=
# AI_API_BASE_URL=http://localhost:11434/v1   # for Ollama
# AI_MODEL_NAME=llama3.1
# AI_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Resend — leave blank to use console mock (emails printed to stdout)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=LeAd <noreply@lead.ai>

# Twilio — leave blank to use console mock (SMS printed to stdout)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=   # E.164 format e.g. +14155238886

# ── Cron Security ─────────────────────────────────────────────────────────────
# REQUIRED — no default. Generate with: openssl rand -hex 32
# Used as the X-Cron-Secret header value when calling /system/cron/* endpoints.
CRON_SECRET=your-random-secret-here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
